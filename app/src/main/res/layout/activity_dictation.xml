<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <!-- 模式切换 -->
        <Button
            android:id="@+id/btnModeEnToCn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="英→中"
            android:textSize="13sp"
            android:backgroundTint="#1976D2"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnModeCnToEn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="中→英"
            android:textSize="13sp"
            android:backgroundTint="#90A4AE"
            android:layout_marginEnd="8dp" />

        <!-- 词库选择 -->
        <Button
            android:id="@+id/btnSelectCategory"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="换词库"
            android:textSize="12sp"
            android:backgroundTint="#7B1FA2" />
    </LinearLayout>

    <!-- 词库名称 & 进度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="四级"
            android:textSize="14sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 30"
            android:textSize="14sp"
            android:textColor="#757575" />
    </LinearLayout>

    <!-- 主内容区（单词/释义） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvMainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="abandon"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSubContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[əˈbændən]"
            android:textSize="16sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 答案输入框 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入中文释义"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4"
                android:textSize="18sp"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 判题进度 -->
        <ProgressBar
            android:id="@+id/progressJudging"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- 判题结果卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvResultLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正确"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvResultDefinition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="标准释义：放弃；遗弃"
                    android:textSize="15sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvResultHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="补充提示："
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="重新默写"
                    android:textSize="13sp"
                    android:layout_gravity="end"
                    android:visibility="gone"
                    android:backgroundTint="#F57C00" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 底部按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnSpeak"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🔊"
            android:padding="0dp"
            android:backgroundTint="#E0E0E0"
            android:textColor="#424242"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="提交判题"
            android:textSize="16sp"
            android:backgroundTint="#1976D2"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="跳过"
            android:textSize="14sp"
            android:backgroundTint="#90A4AE" />
    </LinearLayout>

</LinearLayout>
