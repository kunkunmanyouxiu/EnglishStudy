<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF">

        <Button
            android:id="@+id/btnModeByDate"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="按时间查看"
            android:textSize="13sp"
            android:backgroundTint="#1976D2" />

        <Button
            android:id="@+id/btnModeByCategory"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="按词库查看"
            android:textSize="13sp"
            android:backgroundTint="#90A4AE" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvCurrentFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="筛选：-"
            android:textColor="#616161"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSelectFilter"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="选择"
            android:textSize="12sp"
            android:backgroundTint="#5C6BC0" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="共 0 个已学习单词"
        android:textSize="13sp"
        android:textColor="#757575"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLearnedWords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>

